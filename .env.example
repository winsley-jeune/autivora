# =============================================================================
# Autivora — environment variables
# Copy values into Vercel (Production scope) before deployment.
# Empty values leave the relevant feature disabled — site still builds and runs.
# =============================================================================

# ---- Shopify Storefront API (REQUIRED — site cannot fetch products without these) ----
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ---- Site base URL (REQUIRED for canonical URLs, JSON-LD, sitemap) ----
NEXT_PUBLIC_BASE_URL=https://autivara.com

# ---- Sanity CMS (optional — falls back to lib/mock-db.ts if blank) ----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# =============================================================================
# Analytics & ad pixels — leave blank to keep dormant.
# Paste IDs after creating the accounts in each platform.
# =============================================================================

# Google Analytics 4 — format: G-XXXXXXXXXX
# Create at: https://analytics.google.com
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook + Instagram) Pixel — numeric ID
# Create at: https://business.facebook.com → Events Manager → Connect Data Source → Web
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel — alphanumeric ID
# Create at: https://ads.tiktok.com → Tools → Events → Web Events → Set up
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Pinterest Tag — numeric ID
# Create at: https://ads.pinterest.com → Conversions → Tag Manager
NEXT_PUBLIC_PINTEREST_TAG_ID=

# =============================================================================
# Site verification — for Search Console & ad platforms.
# Paste the content="..." value from each platform's HTML meta tag method.
# =============================================================================

# Google Search Console — content from <meta name="google-site-verification" content="..."/>
# https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — content from <meta name="msvalidate.01" content="..."/>
# https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Yandex Webmaster — content from <meta name="yandex-verification" content="..."/>
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Meta Business Manager — domain verification meta tag
# https://business.facebook.com → Brand Safety → Domains → Verify
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# Pinterest site verification — content from <meta name="p:domain_verify" content="..."/>
NEXT_PUBLIC_PINTEREST_SITE_VERIFICATION=

# TikTok site verification (optional)
NEXT_PUBLIC_TIKTOK_SITE_VERIFICATION=

# =============================================================================
# NOTES
# - Every variable prefixed with NEXT_PUBLIC_ is shipped to the browser.
#   Do not put server-only secrets behind that prefix.
# - Server-only vars (SHOPIFY_STOREFRONT_ACCESS_TOKEN, SANITY_API_TOKEN) stay
#   on the server — safe to commit only the names, never the values.
# - When you populate a pixel/verification ID in Vercel, redeploy to apply.
# =============================================================================
